{% doc %}
  Renders custom hreflang alternate link tags from theme settings.

  Each line in `settings.hreflang_alternates` must be: `hreflang|base_url`
  When `settings.hreflang_append_path` is true, `request.path` is appended to each base URL.

  @example
  {% render '_theme-hreflang' %}
{% enddoc %}

{%- if settings.hreflang_enabled and settings.hreflang_alternates != blank -%}
  {%- liquid
    assign path_suffix = ''
    if settings.hreflang_append_path and request.path != blank
      assign path_suffix = request.path
    endif

    assign alternate_lines = settings.hreflang_alternates | strip | newline_to_br | split: '<br />'
  -%}

  {%- for line in alternate_lines -%}
    {%- liquid
      assign line_stripped = line | strip
      if line_stripped == blank
        continue
      endif

      assign first_char = line_stripped | slice: 0, 1
      if first_char == '#'
        continue
      endif

      assign pipe_parts = line_stripped | split: '|'
      if pipe_parts.size < 2
        continue
      endif

      assign hreflang_code = pipe_parts[0] | strip
      assign base_url = pipe_parts[1] | strip

      if hreflang_code == blank or base_url == blank
        continue
      endif

      unless base_url contains 'http://'
        unless base_url contains 'https://'
          continue
        endunless
      endunless

      assign base_last = base_url | slice: -1, 1
      if base_last == '/'
        assign base_len = base_url.size | minus: 1
        assign base_url = base_url | slice: 0, base_len
      endif

      assign alternate_href = base_url | append: path_suffix
      assign alternate_href = alternate_href | replace: '://', '::SCHEME::'
      assign alternate_href = alternate_href | replace: '//', '/'
      assign alternate_href = alternate_href | replace: '::SCHEME::', '://'
    -%}
    <link
      rel="alternate"
      hreflang="{{ hreflang_code | escape }}"
      href="{{ alternate_href | escape }}"
    >
  {%- endfor -%}
{%- endif -%}
