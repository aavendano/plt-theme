{% doc %}
  Renders the predictive search input and suggestion container.
  Uses Alpine.js for reactivity (debounce, click-outside, escape, ARIA).
{% enddoc %}

<div class="l-header-top__search">
  <script>
    document.addEventListener('alpine:init', () => {
      Alpine.data('predictiveSearch', () => ({
        isOpen: false,
        statusText: '',
        controller: new AbortController(),

        onInput() {
          const term = this.$refs.input.value.trim();
          if (term.length < 2) {
            this.close();
            this.$refs.results.innerHTML = '';
            this.statusText = '';
            return;
          }
          this.statusText = this.$refs.status.dataset.loadingText || '';
          this.getResults(term);
        },

        getResults(term) {
          this.controller.abort();
          this.controller = new AbortController();

          const params = new URLSearchParams({
            q: term,
            'resources[type]': 'product,collection,page,query',
            'resources[limit]': 4,
            'resources[limit_scope]': 'each',
            section_id: 'predictive-search',
          });

          fetch(`${window.Shopify.routes.root}search/suggest?${params}`, {
            signal: this.controller.signal,
          })
            .then((r) => {
              if (!r.ok) throw new Error(r.status);
              return r.text();
            })
            .then((text) => {
              const parsed = new DOMParser().parseFromString(text, 'text/html');
              const section = parsed.querySelector('#shopify-section-predictive-search');
              if (!section) {
                this.close();
                this.statusText = '';
                return;
              }
              this.$refs.results.innerHTML = section.innerHTML;
              this.open();
              this.statusText = this.$refs.status.dataset.updatedText || '';
            })
            .catch((err) => {
              if (err.name === 'AbortError') return;
              this.close();
              this.statusText = '';
            });
        },

        open() {
          this.isOpen = true;
        },

        close() {
          this.isOpen = false;
        },
      }));
    });
  </script>
  <div x-data="predictiveSearch" @click.outside="close()">
    <form
      action="{{ routes.search_url }}"
      method="get"
      role="search"
      class="l-search-form"
    >
      <label class="l-sr-only" for="predictive-search-input">
        {{- 'search.label' | t -}}
      </label>
      <div class="b-control b-has-icons-left b-is-expanded">
        <input
          id="predictive-search-input"
          class="b-input b-is-small b-is-normal-desktop"
          type="search"
          name="q"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder="{{ 'search.placeholder' | t }}"
          role="combobox"
          :aria-expanded="isOpen"
          aria-owns="predictive-search-results"
          aria-controls="predictive-search-results"
          aria-describedby="predictive-search-status"
          aria-haspopup="listbox"
          aria-autocomplete="list"
          x-ref="input"
          @input.debounce.300ms="onInput()"
          @focus="if ($refs.results.innerHTML.trim()) open()"
          @keydown.escape="close(); $refs.input.blur()"
        >
        <input type="hidden" name="options[prefix]" value="last">
        <span class="b-icon b-is-medium b-is-left" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            fill="currentColor"
            viewBox="0 0 16 16"
            focusable="false"
          >
            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
          </svg>
        </span>
      </div>
      <div
        id="predictive-search-results"
        class="l-predictive-results c-glass-effect"
        x-ref="results"
        role="listbox"
        aria-label="{{ 'search.predictive.aria_label' | t }}"
        :hidden="!isOpen"
      ></div>
      <span
        id="predictive-search-status"
        class="l-sr-only predictive-search-status"
        role="status"
        aria-live="polite"
        aria-atomic="true"
        x-ref="status"
        x-text="statusText"
        data-loading-text="{{ 'search.predictive.loading' | t }}"
        data-updated-text="{{ 'search.predictive.results_updated' | t }}"
      ></span>
    </form>
  </div>
</div>
