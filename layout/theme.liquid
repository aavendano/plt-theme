<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {{ 'critical-css.css' | asset_url | stylesheet_tag }}
    {{ 'b-style.source.css' | asset_url | stylesheet_tag }}
    {% # Inlined CSS Variables (overrides Bulma defaults) %}
    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/focus@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/resize@3.x.x/dist/cdn.min.js"></script>
    <script src="{{ 'b-style-alpine.js' | asset_url }}" defer></script>
    <script src="https://cdn.shopify.com/storefront/web-components.js" defer></script>
    {% render 'css-variables' %}

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

      {% comment %} Preload the base font variant for initial page render {% endcomment %}
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body>
    <shopify-store
      store-domain="https://{{ shop.permanent_domain }}"
      country="{{ localization.country.iso_code }}"
      language="{{ localization.language.iso_code }}"
      public-access-token="{{ settings.public_access_token }}"
    >
    </shopify-store>

    {% sections 'header-group' %}

    <div class="b-container b-is-fluid" style="width: 100%; height: 100%;">
      {{ content_for_layout }}
    </div>

    {% sections 'footer-group' %}
  </body>
</html>
