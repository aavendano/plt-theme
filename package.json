{
  "scripts": {
    "build:assets": "npm run build:css && npm run build:js",
    "build:bulma": "sass --load-path=node_modules/b-style/src/bulma node_modules/b-style/src/bulma/bulma.scss assets/b-style.source.css",
    "build:css": "npm run build:bulma && postcss assets/b-style.source.css -o assets/b-style.css",
    "build:css:report": "node scripts/css-size-report.mjs",
    "build:js": "cp node_modules/b-style/dist/alpine.js assets/b-style-alpine.js",
    "postinstall": "npm run build:assets"
  },
  "dependencies": {
    "b-style": "github:aavendano/b-style"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^6.0.0",
    "@shopify/prettier-plugin-liquid": "^1.10.2",
    "cssnano": "^7.0.0",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.8.3",
    "sass": "^1.77.0"
  }
}
