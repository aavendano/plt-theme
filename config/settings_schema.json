[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:settings_schema.logo.name",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "t:settings_schema.logo.settings.logo_image.label"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 300,
        "step": 10,
        "default": 100,
        "unit": "px",
        "label": "t:settings_schema.logo.settings.logo_width.label"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:settings_schema.logo.settings.favicon.label",
        "info": "t:settings_schema.logo.settings.favicon.info"
      },
      {
        "type": "image_picker",
        "id": "favicon_ico",
        "label": "Favicon (.ico file)",
        "info": "Favicon (.ico file)"
      }
    ]
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  },
  {
    "name": "t:general.access_keys",
    "settings": [
      {
        "type": "header",
        "content": "t:general.access_keys"
      },
      {
        "type": "text",
        "id": "public_access_token",
        "label": "t:labels.public_access_token",
        "default": "0000"
      }
    ]
  },
  {
    "name": "t:settings_schema.hreflang.name",
    "settings": [
      {
        "type": "checkbox",
        "id": "hreflang_enabled",
        "label": "t:settings_schema.hreflang.settings.enabled.label",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "hreflang_append_path",
        "label": "t:settings_schema.hreflang.settings.append_path.label",
        "info": "t:settings_schema.hreflang.settings.append_path.info",
        "default": true
      },
      {
        "type": "textarea",
        "id": "hreflang_alternates",
        "label": "t:settings_schema.hreflang.settings.alternates.label",
        "info": "t:settings_schema.hreflang.settings.alternates.info",
        "placeholder": "t:settings_schema.hreflang.settings.alternates.placeholder",
        "default": "x-default|https://playlovetoys.com\nen-CA|https://playlovetoys.ca\nfr-CA|https://playlovetoys.ca/fr\nen-US|https://playlovetoys.com\nes-US|https://playlovetoys.com/es"
      },
      {
        "type": "paragraph",
        "content": "t:settings_schema.hreflang.settings.duplicates.info"
      }
    ]
  }
]
