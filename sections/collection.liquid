{% comment %}
  Collection page — PlayLoveToys design system
  Design ref: .design/playlovetoys-design-system/project/ui_kits/storefront/CollectionScreen.jsx
{% endcomment %}

{%- liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign header_content = collection.metafields['app--6007307--sanity-fields'].header.value
-%}

<!-- Collection Hero -->
<section class="b-section">
  <div class="b-container b-is-desktop">
    {% render 'breadcrumb' %}
    {% render '_collection-hero-collapsable-content',
      collection: collection,
      header_content: header_content,
      section: section
    %}
  </div>
</section>

<!-- Products + Filters -->
<section class="b-section">
  <div id="product-grid-container" class="b-container b-is-desktop">
    {%- paginate collection.products by 20 -%}
      <div class="b-columns b-is-variable b-is-5">
        <!-- Filters Sidebar -->

        <!-- Filters Drawer -->
        {% render 'side-drawer', results: collection %}

        <!-- Product Grid -->
        <div class="b-column">
          <!-- Mobile filter trigger -->
          <div class="b-mb-4">
            {% render 'facets', results: collection, paginate: paginate %}
          </div>
          <!-- PRODUCTS GRID -->
          <!-- PRODUCTS GRID - FALLBACK IF NO PRODUCTS -->
          {%- if collection.products.size == 0 -%}
            <div class="b-has-text-centered b-py-6" id="product-grid" data-id="{{ section.id }}">
              <h2 class="b-title b-is-4">
                {{ 'sections.collection_template.empty' | t }}
                <br>
                {{
                  'sections.collection_template.use_fewer_filters_html'
                  | t: link: collection.url, class: 'b-has-text-link'
                }}
              </h2>
            </div>
          {%- else -%}
            <!-- PRODUCTS GRID - IF PRODUCTS ARE FOUND -->
            <div
              id="product-grid"
              data-id="{{ section.id }}"
              class="b-columns b-is-multiline"
            >
              {%- for product in collection.products -%}
                {% if product.available %}
                  {%- liquid
                    assign target = product.selected_or_first_available_variant
                    assign compare_at_price = target.compare_at_price
                    assign price = target.price | default: 1999
                    assign money_price = price | money_with_currency
                    assign on_sale = false
                    if compare_at_price > price
                      assign on_sale = true
                      assign saved_amount = compare_at_price | minus: price
                      assign saved_pct = saved_amount | times: 100 | divided_by: compare_at_price | round
                    endif
                    assign free_shipping = false
                    if product.price >= 7500
                      assign free_shipping = true
                    endif
                  -%}

                  <div class="b-column b-is-half-tablet b-is-one-third-desktop b-is-one-quarter-widescreen">
                    <div class="b-columns b-is-multiline b-is-mobile">
                      <!-- Card image -->
                      <div class="b-column">
                        <a href="{{ product.url }}">
                          <div class="b-has-image-overlay">
                            {% render 'image',
                              image: product.featured_media,
                              width: 600,
                              height: 600,
                              crop: 'center',
                              class: 'b-is-1by1'
                            %}

                            {% if free_shipping %}
                              <span class="b-badge-primary b-tag-top-left b-is-size-7">Free shipping</span>
                            {% elsif on_sale %}
                              <span class="b-badge-danger b-tag-top-left b-is-size-7">SALE {{ saved_pct }}% OFF</span>
                            {% endif %}
                          </div>
                        </a>
                      </div>

                      <!-- Card content -->
                      <div class="b-column b-is-12-desktop">
                        {% if product.vendor != blank %}
                          <p style="text-transform: uppercase; letter-spacing: .12em; font-size: 11px; color: var(--plt-text-muted); font-weight: 600; margin: 0 0 4px;">
                            {{ product.vendor | escape }}
                          </p>
                        {% endif %}

                        <p class="b-title b-is-6" style="margin-bottom: 6px;">
                          <a href="{{ product.url }}" class="full-unstyled-link">{{ product.title | escape }}</a>
                        </p>

                        <div style="margin-top: auto; padding-top: 8px;">
                          {% if on_sale %}
                            <span style="display: inline-flex; align-items: baseline; gap: 8px; flex-wrap: wrap;">
                              <span class="price-item" style="color: var(--plt-pink); font-weight: 700;">
                                {{- money_price -}}
                              </span>
                              <span class="custom-price-text-was"
                                ><s>{{ compare_at_price | money }}</s></span
                              >
                              <span class="b-tag b-is-danger b-is-light b-is-small">Save {{ saved_pct }}%</span>
                            </span>
                          {% else %}
                            <span class="price-item b-has-text-weight-bold">{{ money_price }}</span>
                          {% endif %}
                        </div>

                        <a href="{{ product.url }}" class="b-button b-is-link b-is-fullwidth" style="margin-top: 12px;">
                          {{- 'products.product.add_to_cart' | t -}}
                        </a>
                      </div>
                    </div>
                  </div>
                {% endif %}
              {%- endfor -%}
            </div>

            {%- if paginate.pages > 1 -%}
              <nav class="b-pagination b-is-centered" style="margin-top: 28px;">
                {% render 'pagination', paginate: paginate, anchor: '' %}
              </nav>
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
    {%- endpaginate -%}
  </div>
</section>

<!-- Brand Editorial -->
{% assign brand_editorial_content = collection.metafields['app--6007307--sanity-fields'].brandEditorial.value %}
{% if brand_editorial_content %}
  {% liquid
    capture localized_brand_title
      render '_sanity-value', items: brand_editorial_content.title, key_prefix: 'bet', locale: sanity_locale
    endcapture
    assign localized_brand_title = localized_brand_title | strip
    assign brand_logo = section.settings.logo | default: settings.logo
  %}
  <section class="b-section">
    <div class="b-container b-is-desktop">
      <div class="b-columns b-is-vcentered">
        {% if brand_logo %}
          <div class="b-column b-is-3">
            <figure class="b-image">
              {{ brand_logo | image_url: width: 300 | image_tag: widths: '50,100,150,200,250,300', loading: 'lazy' }}
            </figure>
          </div>
        {% endif %}
        <div class="b-column {% if brand_logo %}b-is-8{% else %}b-is-12{% endif %}">
          <div class="logo-motto-text-{{ section.id }}">
            {% if localized_brand_title != blank %}
              <h2 class="b-title b-is-6-mobile b-is-1-desktop b-is-capitalized b-has-text-primary">
                {{ localized_brand_title }}
              </h2>
            {% endif %}
            <div class="brand-editorial-body-{{ section.id }} b-content">
              {% render '_sanity-portable-text',
                items: brand_editorial_content.body,
                key_prefix: 'be',
                locale: sanity_locale
              %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
{% endif %}

<!-- After Page Content -->
{% assign after_page_content = collection.metafields['app--6007307--sanity-fields'].afterPageContent.value.body %}
{% if after_page_content != blank %}
  <section class="b-section">
    <div class="b-container b-is-desktop">
      <div class="b-content">
        {% render '_sanity-portable-text', items: after_page_content, key_prefix: 'body', locale: sanity_locale %}
      </div>
    </div>
  </section>
{% endif %}

<!-- SEO FAQs -->
{% assign seo_faqs = collection.metafields['app--6007307--sanity-fields'].faqs.value %}
{% if seo_faqs != blank %}
  <section class="b-section">
    <div class="b-container b-is-desktop">
      {% render '_collection-seo-faqs', faqs: seo_faqs, locale: sanity_locale %}
    </div>
  </section>
{% endif %}

{% style %}
  @media (min-width: 769px) {
    .logo-motto-text-{{ section.id }} {
      margin-left: 2rem;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "t:general.collection",
  "settings": [
    {
      "type": "header",
      "content": "Collection Content"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Brand Logo"
    }
  ]
}
{% endschema %}
