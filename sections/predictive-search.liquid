{%- if predictive_search.performed -%}
  <div class="l-predictive-body">
    {%- if predictive_search.resources.queries.size > 0 -%}
      <div class="l-predictive-group">
        <p class="b-is-size-7 b-has-text-white l-predictive-label">
          {{- 'search.predictive.queries' | t -}}
        </p>
        <ul role="group">
          {%- for query in predictive_search.resources.queries -%}
            <li role="option">
              <a class="b-navbar-item b-has-text-white" href="{{ query.url }}">
                {{- query.text -}}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if predictive_search.resources.products.size > 0 -%}
      <div class="l-predictive-group">
        <p class="b-is-size-7 b-has-text-white l-predictive-label">
          {{- 'search.predictive.products' | t -}}
        </p>

        {%- for product in predictive_search.resources.products -%}
          <a class="b-navbar-item" href="{{ product.url }}">
            <div class="b-media">
              {%- if product.featured_image -%}
                <figure class="b-media-left ">
                  <img
                    x-data="{ imageLoaded: false }"
                    @load="imageLoaded = true"
                    :class="!imageLoaded ? 'b-is-skeleton' : ''"
                    class="b-image b-is-square l-predictive-img"
                    src="{{ product.featured_image | image_url: width: 80, height: 80, crop: 'center' }}"
                    alt="{{ product.featured_image.alt | escape }}"
                  >
                </figure>
              {%- endif -%}
              <div class="b-media-content">
                <div class="b-content">
                  <p class="b-title b-is-size-7 b-is-size-6-desktop b-has-text-primary-light">{{ product.title }}</p>
                  {%- if product.price -%}
                    <p class="b-subtitle b-is-size-7 b-is-size-6-desktop b-has-text-link-light">
                      {{ product.price | money }}
                    </p>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if predictive_search.resources.collections.size > 0 -%}
      <div class="l-predictive-group">
        <p class="b-is-size-7 b-has-text-white l-predictive-label">
          {{- 'search.predictive.collections' | t -}}
        </p>
        <ul role="group">
          {%- for collection in predictive_search.resources.collections -%}
            <li role="option">
              <a class="b-navbar-item b-has-text-white" href="{{ collection.url }}">
                {{- collection.title -}}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if predictive_search.resources.pages.size > 0 -%}
      <div class="l-predictive-group">
        <p class="b-is-size-7 b-has-text-white l-predictive-label">
          {{- 'search.predictive.pages' | t -}}
        </p>
        <ul role="group">
          {%- for page in predictive_search.resources.pages -%}
            <li role="option">
              <a class="b-navbar-item" href="{{ page.url }}">
                {{- page.title -}}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    <div class="l-predictive-footer">
      <a
        class="b-is-size-7"
        href="{{ routes.search_url }}?q={{ predictive_search.terms | url_encode }}&options[prefix]=last"
      >
        {{- 'search.predictive.view_all' | t: terms: predictive_search.terms -}}
      </a>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .l-predictive-body {
    padding-block: 0.25rem;
  }

  .l-predictive-group + .l-predictive-group {
    border-top: 1px solid var(--b-border, rgb(226 232 240));
  }

  .l-predictive-label {
    padding: 0.5rem 0.75rem 0.15rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    margin: 0;
  }

  .l-predictive-img {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.375rem;
    margin-right: 0.5rem;
    object-fit: contain;
    object-position: center;
    background-color: white;
  }

  .l-predictive-footer {
    padding: 0.6rem 0.75rem;
    border-top: 1px solid var(--b-border, rgb(226 232 240));
  }

  @media (min-width: 1024px) {
    .l-predictive-img {
      width: 4rem;
      height: 100%;
      min-height: 4rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "tag": "section",
  "settings": []
}
{% endschema %}
