{%- if predictive_search.performed -%}
  {%- assign predictive_results_count = predictive_search.resources.queries.size
    | plus: predictive_search.resources.products.size
    | plus: predictive_search.resources.collections.size
    | plus: predictive_search.resources.pages.size
    | plus: predictive_search.resources.articles.size
  -%}
  {%- capture view_all_url -%}{{ routes.search_url }}?q={{ predictive_search.terms | url_encode }}&options%5Bprefix%5D=last{%- endcapture -%}

  <div class="predictive-search" role="listbox" aria-label="{{ 'search.predictive.aria_label' | t }}">
    {%- if predictive_results_count > 0 -%}
      <div data-predictive-search-results>
        {%- if predictive_search.resources.queries.size > 0 -%}
          <section class="predictive-search__group">
            <h3 class="predictive-search__title">{{ 'search.predictive.queries' | t }}</h3>
            <ul class="predictive-search__list" role="list">
              {%- for query in predictive_search.resources.queries -%}
                <li>
                  <a class="predictive-search__link" href="{{ query.url }}">
                    {{ query.styled_text | default: query.text | default: query }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </section>
        {%- endif -%}

        {%- if predictive_search.resources.products.size > 0 -%}
          <section class="predictive-search__group">
            <h3 class="predictive-search__title">{{ 'search.predictive.products' | t }}</h3>
            <ul class="predictive-search__list" role="list">
              {%- for product in predictive_search.resources.products -%}
                <li>
                  <a class="predictive-search__link predictive-search__link--product" href="{{ product.url }}">
                    {%- if product.featured_image -%}
                      {{
                        product.featured_image
                        | image_url: width: 80, height: 80
                        | image_tag: class: 'predictive-search__image', loading: 'lazy'
                      }}
                    {%- endif -%}
                    <span class="predictive-search__content">
                      <span class="predictive-search__name">{{ product.title | escape }}</span>
                      {%- if product.price -%}
                        <span class="predictive-search__meta">{{ product.price | money_with_currency }}</span>
                      {%- endif -%}
                    </span>
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </section>
        {%- endif -%}

        {%- if predictive_search.resources.collections.size > 0 -%}
          <section class="predictive-search__group">
            <h3 class="predictive-search__title">{{ 'search.predictive.collections' | t }}</h3>
            <ul class="predictive-search__list" role="list">
              {%- for collection in predictive_search.resources.collections -%}
                <li>
                  <a class="predictive-search__link" href="{{ collection.url }}">{{ collection.title | escape }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </section>
        {%- endif -%}

        {%- if predictive_search.resources.pages.size > 0 -%}
          <section class="predictive-search__group">
            <h3 class="predictive-search__title">{{ 'search.predictive.pages' | t }}</h3>
            <ul class="predictive-search__list" role="list">
              {%- for page in predictive_search.resources.pages -%}
                <li>
                  <a class="predictive-search__link" href="{{ page.url }}">{{ page.title | escape }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </section>
        {%- endif -%}

        {%- if predictive_search.resources.articles.size > 0 -%}
          <section class="predictive-search__group">
            <h3 class="predictive-search__title">{{ 'search.predictive.articles' | t }}</h3>
            <ul class="predictive-search__list" role="list">
              {%- for article in predictive_search.resources.articles -%}
                <li>
                  <a class="predictive-search__link" href="{{ article.url }}">{{ article.title | escape }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </section>
        {%- endif -%}
      </div>
    {%- else -%}
      <p class="predictive-search__empty" data-predictive-search-empty>{{ 'search.predictive.no_results' | t }}</p>
    {%- endif -%}

    <div class="predictive-search__footer">
      <a class="predictive-search__view-all" href="{{ view_all_url }}">
        {{ 'search.predictive.view_all' | t: terms: predictive_search.terms }}
      </a>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .predictive-search {
    padding: 0.65rem;
    color: #0f172a;
  }

  .predictive-search__group + .predictive-search__group {
    margin-top: 0.7rem;
  }

  .predictive-search__title {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 600;
    color: #64748b;
  }

  .predictive-search__list {
    margin: 0.35rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.2rem;
  }

  .predictive-search__link {
    display: block;
    border-radius: 0.5rem;
    padding: 0.42rem 0.55rem;
    color: inherit;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .predictive-search__link:hover,
  .predictive-search__link:focus-visible {
    background: #f1f5f9;
    outline: none;
  }

  .predictive-search__link--product {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .predictive-search__image {
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 0.5rem;
    object-fit: cover;
  }

  .predictive-search__content {
    display: grid;
    gap: 0.1rem;
  }

  .predictive-search__name {
    font-size: 0.9rem;
  }

  .predictive-search__meta {
    font-size: 0.8rem;
    color: #64748b;
  }

  .predictive-search__empty {
    margin: 0.2rem 0;
    padding: 0.3rem 0.55rem;
    font-size: 0.85rem;
  }

  .predictive-search__footer {
    margin-top: 0.7rem;
    padding-top: 0.65rem;
    border-top: 1px solid rgb(226 232 240);
  }

  .predictive-search__view-all {
    color: inherit;
    font-size: 0.85rem;
    text-decoration: underline;
    text-underline-offset: 0.15rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
