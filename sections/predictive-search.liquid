{%- if predictive_search.performed -%}
  <div class="predictive-search">
    {%- if predictive_search.resources.queries.size > 0 -%}
      <div class="predictive-group">
        <p class="predictive-group__label" id="ps-queries-label">
          {{- 'search.predictive.queries' | t -}}
        </p>
        <ul class="predictive-list" aria-labelledby="ps-queries-label" role="group">
          {%- for query in predictive_search.resources.queries -%}
            <li class="predictive-item" role="option">
              <a class="predictive-item__link" href="{{ query.url }}">
                <span class="predictive-item__title">{{ query.text }}</span>
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if predictive_search.resources.products.size > 0 -%}
      <div class="predictive-group">
        <p class="predictive-group__label" id="ps-products-label">
          {{- 'search.predictive.products' | t -}}
        </p>
        <ul class="predictive-list" aria-labelledby="ps-products-label" role="group">
          {%- for product in predictive_search.resources.products -%}
            <li class="predictive-item" role="option">
              <a class="predictive-item__link" href="{{ product.url }}">
                {%- if product.featured_image -%}
                  <img
                    class="predictive-item__image"
                    src="{{ product.featured_image | image_url: width: 80, height: 80, crop: 'center' }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    width="40"
                    height="40"
                    loading="lazy"
                  >
                {%- endif -%}
                <span class="predictive-item__text">
                  <span class="predictive-item__title">{{ product.title }}</span>
                  {%- if product.price -%}
                    <span class="predictive-item__price">{{ product.price | money }}</span>
                  {%- endif -%}
                </span>
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    <div class="predictive-footer">
      <a
        class="predictive-footer__link"
        href="{{ routes.search_url }}?q={{ predictive_search.terms | url_encode }}&options[prefix]=last"
      >
        {{- 'search.predictive.view_all' | t: terms: predictive_search.terms -}}
      </a>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:general.search",
  "tag": "section",
  "settings": []
}
{% endschema %}
