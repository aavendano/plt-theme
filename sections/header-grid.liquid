<header x-data="{ menuOpen: false }">
  <div class="l-header-wrapper-dev b-mb-5">
    <div class="b-container">
      <div class="l-header-top">
        <div class="l-header-top__logo">
          <a href="{{ routes.root_url }}">
            {% if settings.logo %}
              <img src="{{ settings.logo | image_url: width: 100 }}" alt="{{ shop.name }}" width="100" height="100">
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'l-logo-placeholder' }}
            {% endif %}
          </a>
        </div>
        <div class="l-header-top__search">
          <predictive-search class="l-search">
            <form
              action="{{ routes.search_url }}"
              method="get"
              role="search"
              class="l-search__form"
            >
              <label class="l-visually-hidden" for="predictive-search-input">
                {{- 'search.label' | t -}}
              </label>
              <input
                id="predictive-search-input"
                class="l-search__input b-input b-is-medium b-is-rounded"
                type="search"
                name="q"
                autocomplete="off"
                autocorrect="off"
                autocapitalize="off"
                spellcheck="false"
                placeholder="{{ 'search.placeholder' | t }}"
                role="combobox"
                aria-expanded="false"
                aria-owns="predictive-search-results"
                aria-controls="predictive-search-results"
                aria-haspopup="listbox"
                aria-autocomplete="list"
                data-predictive-input
              >
              <input type="hidden" name="options[prefix]" value="last">
              <button
                type="submit"
                class="l-search__submit"
                aria-label="{{ 'search.submit' | t }}"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                  <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                </svg>
              </button>
              <div
                id="predictive-search-results"
                class="l-search__results"
                data-predictive-results
                role="listbox"
                aria-label="{{ 'search.predictive.aria_label' | t }}"
                hidden
              ></div>
            </form>
          </predictive-search>
        </div>
        <div class="l-header-top__actions">
          <div class="l-desktop-only">
            {% render '_navbar-end' %}
          </div>
          <button
            class="b-navbar-burger b-has-text-white l-burger"
            :class="menuOpen ? 'b-is-active' : ''"
            @click="menuOpen = !menuOpen"
            aria-label="menu"
            :aria-expanded="menuOpen"
          >
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
    </div>

    <div class="l-bg-dark b-py-2" :class="menuOpen ? 'l-nav--open' : ''">
      <div class="l-nav-menu-wrapper" :class="menuOpen ? '' : 'l-nav-menu--closed'">
        {% render '_navbar-menu', links: section.settings.menu.links %}
      </div>
    </div>
  </div>
</header>

{% style %}
  .l-header-wrapper {
    background-image: linear-gradient(
      115deg,
      rgba(35, 31, 32, 1) 0%,
      rgba(83, 50, 120, 1) 50%,
      rgba(244, 67, 108, 1) 100%
    ) !important;
    max-width: 100vw;
    width: 100%;
    overflow-x: hidden;
  }

  .l-header-wrapper-dev {
    background-color: skyblue !important;
    max-width: 100vw;
    width: 100%;
  }

  .l-bg-dark {
    background-image: linear-gradient(
      115deg,
      rgba(0, 0, 0, 60%) 0%,
      rgba(0, 0, 0, 45%) 20%,
      rgba(0, 0, 0, 60%) 40%,
      rgba(0, 0, 0, 50%) 60%,
      rgba(0, 0, 0, 70%) 80%,
      rgba(0, 0, 0, 55%) 100%
    ) !important;
    position: relative;
    overflow: visible;
  }

  .l-header-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
  }

  .l-header-top__logo {
    flex-shrink: 0;
  }

  .l-header-top__search {
    flex: 1;
    min-width: 0;
  }

  .l-search {
    display: block;
    position: relative;
    width: 100%;
  }

  .l-search__form {
    position: relative;
    width: 100%;
  }

  .l-search__input {
    width: 100%;
    padding-right: 2.75rem;
  }

  .l-search__submit {
    position: absolute;
    inset-block: 0;
    right: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0 0.4rem;
    color: inherit;
  }

  .l-search__submit:hover {
    opacity: 0.75;
  }

  .l-search__results {
    position: absolute;
    inset-inline: 0;
    top: calc(100% + 0.35rem);
    z-index: 100;
    background: #fff;
    border-radius: 0.75rem;
    box-shadow:
      0 16px 40px rgba(15, 23, 42, 0.16),
      0 0 0 1px rgba(148, 163, 184, 0.2);
    max-height: min(70vh, 480px);
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .l-visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .predictive-search {
    padding-block: 0.4rem;
    color: rgb(15 23 42);
  }

  .predictive-group + .predictive-group {
    border-top: 1px solid rgb(226 232 240);
  }

  .predictive-group__label {
    padding: 0.45rem 0.9rem 0.2rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: rgb(100 116 139);
    margin: 0;
  }

  .predictive-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .predictive-item__link {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0.9rem;
    text-decoration: none;
    color: inherit;
  }

  .predictive-item__link:hover,
  .predictive-item__link:focus-visible {
    outline: none;
    background: rgb(241 245 249);
  }

  .predictive-item__image {
    flex: 0 0 auto;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.375rem;
    object-fit: cover;
  }

  .predictive-item__text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .predictive-item__title {
    font-size: 0.875rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .predictive-item__price {
    font-size: 0.8rem;
    color: rgb(100 116 139);
  }

  .predictive-footer {
    padding: 0.6rem 0.9rem 0.75rem;
    border-top: 1px solid rgb(226 232 240);
  }

  .predictive-footer__link {
    font-size: 0.85rem;
    color: rgb(15 23 42);
    text-decoration: underline;
  }

  .predictive-footer__link:hover {
    opacity: 0.75;
  }

  .l-header-top__actions {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .l-burger {
    display: none;
  }

  .l-desktop-only {
    display: flex;
    align-items: center;
  }

  @media screen and (max-width: 1023px) {
    .l-burger {
      display: flex;
    }

    .l-desktop-only {
      display: none;
    }

    .l-nav-menu--closed {
      display: none;
    }

    .l-nav--open .b-navbar-menu {
      display: flex;
      flex-direction: column;
      align-items: stretch;
    }
  }
{% endstyle %}

{% javascript %}
class PredictiveSearch extends HTMLElement {
  constructor() {
    super();
    this.input = this.querySelector('[data-predictive-input]');
    this.results = this.querySelector('[data-predictive-results]');
    this.controller = new AbortController();
    this.onInput = this.debounce(this.onInput.bind(this), 300);
    this.onClickOutside = this.onClickOutside.bind(this);
  }

  connectedCallback() {
    this.input.addEventListener('input', this.onInput);
    this.input.addEventListener('focus', () => {
      if (this.results.innerHTML.trim()) this.open();
    });
    this.input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        this.close();
        this.input.blur();
      }
    });
    document.addEventListener('click', this.onClickOutside);
  }

  disconnectedCallback() {
    document.removeEventListener('click', this.onClickOutside);
  }

  onClickOutside(e) {
    if (!this.contains(e.target)) this.close();
  }

  onInput() {
    const term = this.input.value.trim();
    if (term.length < 2) {
      this.close();
      this.results.innerHTML = '';
      return;
    }
    this.getResults(term);
  }

  getResults(term) {
    this.controller.abort();
    this.controller = new AbortController();

    const params = new URLSearchParams({
      q: term,
      'resources[type]': 'product,collection,page,query',
      'resources[limit]': 5,
      section_id: 'predictive-search'
    });

    fetch(`${window.Shopify.routes.root}search/suggest?${params}`, {
      signal: this.controller.signal
    })
      .then((r) => {
        if (!r.ok) throw new Error(r.status);
        return r.text();
      })
      .then((text) => {
        const parsed = new DOMParser().parseFromString(text, 'text/html');
        const section = parsed.querySelector('#shopify-section-predictive-search');
        if (!section) {
          this.close();
          return;
        }
        this.results.innerHTML = section.innerHTML;
        this.open();
      })
      .catch((err) => {
        if (err.name === 'AbortError') return;
        this.close();
      });
  }

  open() {
    this.results.hidden = false;
    this.input.setAttribute('aria-expanded', 'true');
  }

  close() {
    this.results.hidden = true;
    this.input.setAttribute('aria-expanded', 'false');
  }

  debounce(fn, delay) {
    let timer;
    return (...args) => {
      clearTimeout(timer);
      timer = setTimeout(() => fn.apply(this, args), delay);
    };
  }
}

customElements.define('predictive-search', PredictiveSearch);
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
