<header x-data="{ menuOpen: false }">
  <div class="l-header-wrapper-dev b-mb-5">
    <div class="b-container">
      <div class="l-header-top">
        <div class="l-header-top__logo">
          <a href="{{ routes.root_url }}">
            {% if settings.logo %}
              <img src="{{ settings.logo | image_url: width: 100 }}" alt="{{ shop.name }}" width="100" height="100">
            {% else %}
              <img src="https://placehold.net/default.svg" alt="{{ shop.name }}" width="100" height="100">
            {% endif %}
          </a>
        </div>
        <div class="l-header-top__search">
          <input
            class="b-input b-is-medium b-is-rounded"
            type="text"
            placeholder="Large input"
          >
        </div>
        <div class="l-header-top__actions">
          <div class="l-desktop-only">
            {% render '_navbar-end' %}
          </div>
          <button
            class="b-navbar-burger b-has-text-white l-burger"
            :class="menuOpen ? 'b-is-active' : ''"
            @click="menuOpen = !menuOpen"
            aria-label="menu"
            :aria-expanded="menuOpen"
          >
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
    </div>

    <div class="l-bg-dark b-py-2" :class="menuOpen ? 'l-nav--open' : ''">
      <div class="l-nav-menu-wrapper" :class="menuOpen ? '' : 'l-nav-menu--closed'">
        {% render '_navbar-menu', links: section.settings.menu.links %}
      </div>
    </div>
  </div>
</header>

{% style %}
  .l-header-wrapper {
    background-image: linear-gradient(
      115deg,
      rgba(35, 31, 32, 1) 0%,
      rgba(83, 50, 120, 1) 50%,
      rgba(244, 67, 108, 1) 100%
    ) !important;
    max-width: 100vw;
    width: 100%;
    overflow-x: hidden;
  }

  .l-header-wrapper-dev {
    background-color: skyblue !important;
    max-width: 100vw;
    width: 100%;
  }

  .l-bg-dark {
    background-image: linear-gradient(
      115deg,
      rgba(0, 0, 0, 60%) 0%,
      rgba(0, 0, 0, 45%) 20%,
      rgba(0, 0, 0, 60%) 40%,
      rgba(0, 0, 0, 50%) 60%,
      rgba(0, 0, 0, 70%) 80%,
      rgba(0, 0, 0, 55%) 100%
    ) !important;
    position: relative;
    overflow: visible;
  }

  .l-header-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
  }

  .l-header-top__logo {
    flex-shrink: 0;
  }

  .l-header-top__search {
    flex: 1;
  }

  .l-header-top__actions {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .l-burger {
    display: none;
  }

  .l-desktop-only {
    display: flex;
    align-items: center;
  }

  @media screen and (max-width: 1023px) {
    .l-burger {
      display: flex;
    }

    .l-desktop-only {
      display: none;
    }

    .l-nav-menu--closed {
      display: none;
    }

    .l-nav--open .b-navbar-menu {
      display: flex;
      flex-direction: column;
      align-items: stretch;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
