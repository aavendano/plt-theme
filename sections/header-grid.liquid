<header x-data="{ menuOpen: false }">
  <div
    class="l-header-wrapper b-mb-5 l-header-bg-gradient"
    :class="menuOpen ? 'l-overlay-background-color' : ''"
  >
    <div class="b-container">
      <div class="l-header-top">
        <div class="l-header-top__logo">
          <a href="{{ routes.root_url }}">
            {% if settings.logo %}
              <figure class="b-image l-header-logo">
                <img src="{{ settings.logo | image_url: width: 100 }}" alt="{{ shop.name }}" width="100%" height="100%">
              </figure>
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'l-logo-placeholder' }}
            {% endif %}
          </a>
        </div>

        {% render 'predictive-search' %}

        <div class="l-header-top__actions">
          <div class="l-desktop-only">
            {% render '_navbar-end' %}
          </div>
          <button
            class="b-navbar-burger b-has-text-white l-burger"
            :class="menuOpen ? 'b-is-active' : ''"
            @click="menuOpen = !menuOpen"
            aria-label="menu"
            :aria-expanded="menuOpen"
          >
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
    </div>

    <div
      role="navigation"
      aria-label="Main navigation"
      class="l-navbar-menu-position b-py-0 b-py-2-desktop  l-overlay-background-color"
      :class="menuOpen ? 'l-nav--open' : ''"
    >
      <div :class="menuOpen ? '' : 'l-nav-menu--closed'">
        {% render '_navbar-menu', links: section.settings.menu.links %}
      </div>
    </div>
  </div>
</header>

{% style %}
  .l-overlay-background-color {
    background-color:  rgba(9, 10, 12, 0.92); !important;
  }
  .l-header-wrapper {
    max-width: 100vw;
    width: 100%;
  }
  .l-header-bg-gradient {
    background-image: linear-gradient(
      115deg,
      rgba(35, 31, 32, 1) 0%,
      rgba(83, 50, 120, 1) 50%,
      rgba(244, 67, 108, 1) 100%
    );
  }

  .l-bg-dark {
    background-image: linear-gradient(
      115deg,
      rgba(0, 0, 0, 60%) 0%,
      rgba(0, 0, 0, 45%) 20%,
      rgba(0, 0, 0, 55%) 40%,
      rgba(0, 0, 0, 70%) 60%,
      rgba(0, 0, 0, 60%) 80%,
      rgba(0, 0, 0, 50%) 100%
    ) !important;
  }

  .l-navbar-menu-position {
    position: relative;
    overflow: visible;
  }

  /* Header bar: logo + growing search + actions in a single row */
  .l-header-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
  }

  .l-header-top__logo {
    flex-shrink: 0;
  }

  .l-header-top__search {
    flex: 1;
    min-width: 0;
  }

  .l-header-top__actions {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  /* Accessibility: visually-hidden label */
  .l-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Anchor context for the predictive dropdown */
  .l-search-form {
    position: relative;
  }

  /* Predictive results dropdown – no Bulma equivalent */
  .l-predictive-results {
    position: absolute;
    inset-inline: 0;
    top: calc(100% + 0.25rem);
    z-index: 100;
    border-radius: 0.5rem;
    box-shadow: 0 8px 32px rgba(15, 23, 42, 0.14), 0 0 0 1px rgba(148, 163, 184, 0.18);
    max-height: min(70vh, 480px);
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  /* Mobile-first: burger shown, desktop nav hidden */
  .l-desktop-only {
    display: none;
  }

  .l-nav-menu--closed {
    display: none;
  }

  .l-nav--open .b-navbar-menu {
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }
  .l-header-logo {
    width: 4rem;
    height: auto;
    object-fit: contain;
  }

  @media screen and (max-width: 1151px) {
    .l-predictive-results {
      position: fixed;
      inset-inline: 0;
      width: auto;
      top: var(--predictive-results-top, 0);
      border-radius: 0;
      max-height: min(70vh, calc(100dvh - var(--predictive-results-top, 0px) - env(safe-area-inset-bottom, 0px)));
    }
  }

  /* Desktop: flip visibility */
  @media screen and (min-width: 1152px) {
    .l-desktop-only {
      display: flex;
      align-items: center;
    }

    .l-burger {
      display: none;
    }

    .l-nav-menu--closed {
      display: block;
    }
    .l-header-logo {
      width: 5.5rem;
      height: auto;
      object-fit: contain;
    }
    .l-bg-dark {
      background-image: linear-gradient(
        115deg,
        rgba(0, 0, 0, 60%) 0%,
        rgba(0, 0, 0, 45%) 20%,
        rgba(0, 0, 0, 55%) 40%,
        rgba(0, 0, 0, 70%) 60%,
        rgba(0, 0, 0, 60%) 80%,
        rgba(0, 0, 0, 50%) 100%
      ) !important;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
