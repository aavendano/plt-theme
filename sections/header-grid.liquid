<header x-data="{ menuOpen: false }">
  <div class="l-header-wrapper-dev b-mb-5">
    <div class="b-container">
      <div class="l-header-top">
        <div class="l-header-top__logo">
          <a href="{{ routes.root_url }}">
            {% if settings.logo %}
              <img src="{{ settings.logo | image_url: width: 100 }}" alt="{{ shop.name }}" width="100" height="100">
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'l-logo-placeholder' }}
            {% endif %}
          </a>
        </div>

        <div class="l-header-top__search">
          <predictive-search>
            <form
              action="{{ routes.search_url }}"
              method="get"
              role="search"
              class="l-search-form"
            >
              <label class="l-sr-only" for="predictive-search-input">
                {{- 'search.label' | t -}}
              </label>
              <div class="b-control b-has-icons-left b-is-expanded">
                <input
                  id="predictive-search-input"
                  class="b-input b-is-medium b-is-rounded"
                  type="search"
                  name="q"
                  autocomplete="off"
                  autocorrect="off"
                  autocapitalize="off"
                  spellcheck="false"
                  placeholder="{{ 'search.placeholder' | t }}"
                  role="combobox"
                  aria-expanded="false"
                  aria-owns="predictive-search-results"
                  aria-controls="predictive-search-results"
                  aria-haspopup="listbox"
                  aria-autocomplete="list"
                  data-predictive-input
                >
                <input type="hidden" name="options[prefix]" value="last">
                <span class="b-icon b-is-medium b-is-left" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" focusable="false">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                  </svg>
                </span>
              </div>
              <div
                id="predictive-search-results"
                class="l-predictive-results"
                data-predictive-results
                role="listbox"
                aria-label="{{ 'search.predictive.aria_label' | t }}"
                hidden
              ></div>
            </form>
          </predictive-search>
        </div>

        <div class="l-header-top__actions">
          <div class="l-desktop-only">
            {% render '_navbar-end' %}
          </div>
          <button
            class="b-navbar-burger b-has-text-white l-burger"
            :class="menuOpen ? 'b-is-active' : ''"
            @click="menuOpen = !menuOpen"
            aria-label="menu"
            :aria-expanded="menuOpen"
          >
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
    </div>

    <div class="l-bg-dark b-py-2" :class="menuOpen ? 'l-nav--open' : ''">
      <div :class="menuOpen ? '' : 'l-nav-menu--closed'">
        {% render '_navbar-menu', links: section.settings.menu.links %}
      </div>
    </div>
  </div>
</header>

{% style %}
  .l-header-wrapper {
    background-image: linear-gradient(
      115deg,
      rgba(35, 31, 32, 1) 0%,
      rgba(83, 50, 120, 1) 50%,
      rgba(244, 67, 108, 1) 100%
    ) !important;
    max-width: 100vw;
    width: 100%;
    overflow-x: hidden;
  }

  .l-header-wrapper-dev {
    background-color: skyblue !important;
    max-width: 100vw;
    width: 100%;
  }

  .l-bg-dark {
    background-image: linear-gradient(
      115deg,
      rgba(0, 0, 0, 60%) 0%,
      rgba(0, 0, 0, 45%) 20%,
      rgba(0, 0, 0, 60%) 40%,
      rgba(0, 0, 0, 50%) 60%,
      rgba(0, 0, 0, 70%) 80%,
      rgba(0, 0, 0, 55%) 100%
    ) !important;
    position: relative;
    overflow: visible;
  }

  /* Header bar: logo + growing search + actions in a single row */
  .l-header-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
  }

  .l-header-top__logo {
    flex-shrink: 0;
  }

  .l-header-top__search {
    flex: 1;
    min-width: 0;
  }

  .l-header-top__actions {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  /* Accessibility: visually-hidden label */
  .l-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Anchor context for the predictive dropdown */
  .l-search-form {
    position: relative;
  }

  /* Predictive results dropdown – no Bulma equivalent */
  .l-predictive-results {
    position: absolute;
    inset-inline: 0;
    top: calc(100% + 0.25rem);
    z-index: 100;
    background: white;
    border-radius: 0.5rem;
    box-shadow:
      0 8px 32px rgba(15, 23, 42, 0.14),
      0 0 0 1px rgba(148, 163, 184, 0.18);
    max-height: min(70vh, 480px);
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  /* Mobile-first: burger shown, desktop nav hidden */
  .l-desktop-only {
    display: none;
  }

  .l-nav-menu--closed {
    display: none;
  }

  .l-nav--open .b-navbar-menu {
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  /* Desktop: flip visibility */
  @media screen and (min-width: 1024px) {
    .l-desktop-only {
      display: flex;
      align-items: center;
    }

    .l-burger {
      display: none;
    }

    .l-nav-menu--closed {
      display: block;
    }
  }
{% endstyle %}

{% javascript %}
class PredictiveSearch extends HTMLElement {
  constructor() {
    super();
    this.input = this.querySelector('[data-predictive-input]');
    this.results = this.querySelector('[data-predictive-results]');
    this.controller = new AbortController();
    this.onInput = this.debounce(this.onInput.bind(this), 300);
    this.onClickOutside = this.onClickOutside.bind(this);
  }

  connectedCallback() {
    this.input.addEventListener('input', this.onInput);
    this.input.addEventListener('focus', () => {
      if (this.results.innerHTML.trim()) this.open();
    });
    this.input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        this.close();
        this.input.blur();
      }
    });
    document.addEventListener('click', this.onClickOutside);
  }

  disconnectedCallback() {
    document.removeEventListener('click', this.onClickOutside);
  }

  onClickOutside(e) {
    if (!this.contains(e.target)) this.close();
  }

  onInput() {
    const term = this.input.value.trim();
    if (term.length < 2) {
      this.close();
      this.results.innerHTML = '';
      return;
    }
    this.getResults(term);
  }

  getResults(term) {
    this.controller.abort();
    this.controller = new AbortController();

    const params = new URLSearchParams({
      q: term,
      'resources[type]': 'product,collection,page,query',
      'resources[limit]': 5,
      section_id: 'predictive-search'
    });

    fetch(`${window.Shopify.routes.root}search/suggest?${params}`, {
      signal: this.controller.signal
    })
      .then((r) => {
        if (!r.ok) throw new Error(r.status);
        return r.text();
      })
      .then((text) => {
        const parsed = new DOMParser().parseFromString(text, 'text/html');
        const section = parsed.querySelector('#shopify-section-predictive-search');
        if (!section) {
          this.close();
          return;
        }
        this.results.innerHTML = section.innerHTML;
        this.open();
      })
      .catch((err) => {
        if (err.name === 'AbortError') return;
        this.close();
      });
  }

  open() {
    this.results.hidden = false;
    this.input.setAttribute('aria-expanded', 'true');
  }

  close() {
    this.results.hidden = true;
    this.input.setAttribute('aria-expanded', 'false');
  }

  debounce(fn, delay) {
    let timer;
    return (...args) => {
      clearTimeout(timer);
      timer = setTimeout(() => fn.apply(this, args), delay);
    };
  }
}

customElements.define('predictive-search', PredictiveSearch);
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
