<header>
  <div class="l-header-wrapper-dev b-mb-5 " style="background-color: blue;">
    <div class="b-container">
      <div class="b-fixed-grid b-has-4-cols">
        <div class="b-grid b-my-0">
          <div class="b-cell b-mx-auto b-my-auto">
            <a href="{{ routes.root_url }}">
              {% if settings.logo %}
                <img src="{{ settings.logo | image_url: width: 100 }}" alt="{{ shop.name }}" width="100" height="100">
              {% else %}
                <img src="https://placehold.net/default.svg" alt="{{ shop.name }}" width="100" height="100">
              {% endif %}
            </a>
          </div>
          <div class="b-cell b-is-col-span-2 b-py-3 b-my-auto">
            <input
              class="b-input b-is-medium b-is-rounded"
              type="text"
              placeholder="Large input"
            >
          </div>
          <div class="b-cell b-mx-auto b-my-auto">
            <div class="b-navbar-end">
              {% render '_navbar-end' %}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="b-is-flex b-is-justify-content-center b-py-2 l-bg-dark">
      {% render '_navbar-menu', links: section.settings.menu.links %}
    </div>
  </div>
</header>
{% style %}
  .l-header-wrapper {
    background-image: linear-gradient(
      115deg,
      rgba(35, 31, 32, 1) 0%,
      rgba(83, 50, 120, 1) 50%,
      rgba(244, 67, 108, 1) 100%
    ) !important;
    max-width: 100vw;
    width: 100%;
    overflow-x: hidden;
  }

  .l-header-wrapper-dev {
    background-color: skyblue !important;
    max-width: 100vw;
    width: 100%;
  }

  .l-bg-dark {
    background-image: linear-gradient(
      115deg,
      rgba(0, 0, 0, 60%) 0%,
      rgba(0, 0, 0, 45%) 20%,
      rgba(0, 0, 0, 60%) 40%,
      rgba(0, 0, 0, 50%) 60%,
      rgba(0, 0, 0, 70%) 80%,
      rgba(0, 0, 0, 55%) 100%
    ) !important;
  }
{% endstyle %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
