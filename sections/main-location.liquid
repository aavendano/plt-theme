          "type": "collection",
          "id": "collection",
          "label": "t:sections.location.collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.location.label_optional"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.location.image_optional"
        },
        {
