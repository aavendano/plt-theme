{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/commerce/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "ui_kits/storefront/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Roboto Condensed|Fredoka))/i]",
        "message": "Font not provided by the design system. Available: Roboto Condensed, Fredoka."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|size|variant|rounded|loading|fullWidth|as|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: color, size, variant, rounded, loading, fullWidth, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium|large)$/]",
        "message": "<Button> size must be one of 'small' | 'medium' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|children|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|help|helpState|grouped|expanded|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, help, helpState, grouped, expanded."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute[name.name='helpState'] > Literal[value!=/^(?:success|warning|danger|info)$/]",
        "message": "<Field> helpState must be one of 'success' | 'warning' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Message'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|title|onDelete|key|ref|className|style|children)$/]",
        "message": "<Message> doesn't accept that prop. Declared props: color, title, onDelete."
      },
      {
        "selector": "JSXOpeningElement[name.name='Message'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:primary|link|info|success|warning|danger|dark)$/]",
        "message": "<Message> color must be one of 'primary' | 'link' | 'info' | 'success' | 'warning' | 'danger' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Notification'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|light|onDelete|key|ref|className|style|children)$/]",
        "message": "<Notification> doesn't accept that prop. Declared props: color, light, onDelete."
      },
      {
        "selector": "JSXOpeningElement[name.name='Notification'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:primary|link|info|success|warning|danger)$/]",
        "message": "<Notification> color must be one of 'primary' | 'link' | 'info' | 'success' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:price|compareAt|saveLabel|key|ref|className|style|children)$/]",
        "message": "<PriceTag> doesn't accept that prop. Declared props: price, compareAt, saveLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|vendor|price|compareAt|saveLabel|badge|badgeColor|badgePosition|rating|reviewCount|image|imageBg|ctaLabel|onAdd|onOpen|className|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: title, vendor, price, compareAt, saveLabel, badge, badgeColor, badgePosition, rating, reviewCount, image, imageBg, ctaLabel, onAdd, onOpen, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute[name.name='badgeColor'] > Literal[value!=/^(?:primary|link|info|success|warning|danger|dark)$/]",
        "message": "<ProductCard> badgeColor must be one of 'primary' | 'link' | 'info' | 'success' | 'warning' | 'danger' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute[name.name='badgePosition'] > Literal[value!=/^(?:top-left|top-right|bottom-left|bottom-right|center)$/]",
        "message": "<ProductCard> badgePosition must be one of 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:fullWidth|size|state|rounded|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: fullWidth, size, state, rounded."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium|large)$/]",
        "message": "<Select> size must be one of 'small' | 'medium' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:success|warning|danger)$/]",
        "message": "<Select> state must be one of 'success' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|count|size|key|ref|className|style|children)$/]",
        "message": "<StarRating> doesn't accept that prop. Declared props: value, max, count, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|size|light|rounded|deletable|onDelete|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: color, size, light, rounded, deletable, onDelete."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium|large)$/]",
        "message": "<Tag> size must be one of 'small' | 'medium' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|size|rounded|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: state, size, rounded."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:success|warning|danger|info|primary|link)$/]",
        "message": "<TextInput> state must be one of 'success' | 'warning' | 'danger' | 'info' | 'primary' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium|large)$/]",
        "message": "<TextInput> size must be one of 'small' | 'medium' | 'large'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
